# macOS
.DS_Store

# 编辑器
.vscode/
.idea/

# 日志与临时文件
*.log
*.tmp

# Python 环境与缓存
.venv/
__pycache__/
*.pyc

# 私有一手输入（含大体积源文档/网盘提取码/客户数据，本仓库为 PUBLIC）——整个 raw/ 不入库
# 抽取出的结构化文本见 reference-data/，录音转写见 inputs/
raw/

# 字体二进制（体积大、可从官方复现）；保留 assets/fonts/README.md 与 LICENSE.txt
assets/fonts/*.otf
assets/fonts/*.ttf
assets/fonts/*.ttc

# 工具临时产物（剖析/校验/清单等中间文件，以 _ 前缀约定）
tools/_*
**/_dump*.txt
**/_*.csv

# 原型构建产物（由 tools/build_prototype.py 生成，可随时重建）
prototype/
